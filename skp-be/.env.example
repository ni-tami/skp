# DATABASE_URL="sqlite+aiosqlite:///./local.db"
DATABASE_URL="postgresql+asyncpg://postgres:PW@DBHOST:DBPORT/postgres"
# Auth
JWT_SECRET=change-me-please-32-chars-min
JWT_EXPIRES_MINUTES=1440

# Expo push
EXPO_ACCESS_TOKEN=EXPO_ACCESS_TOKEN

# CORS: comma-separated list of allowed origins (use * for MVP)
CORS_ORIGINS=*